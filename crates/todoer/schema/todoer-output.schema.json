{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "todoer CLI output",
  "type": "object",
  "oneOf": [
    { "$ref": "#/definitions/okResponse" },
    { "$ref": "#/definitions/errorResponse" }
  ],
  "definitions": {
    "okResponse": {
      "type": "object",
      "required": ["ok", "command", "data"],
      "properties": {
        "ok": { "const": true },
        "command": { "type": "string" },
        "data": {}
      },
      "additionalProperties": false
    },
    "errorResponse": {
      "type": "object",
      "required": ["ok", "command", "error"],
      "properties": {
        "ok": { "const": false },
        "command": { "type": "string" },
        "error": {
          "type": "object",
          "required": ["code", "message", "details"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" },
            "details": {}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
