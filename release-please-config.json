{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    "crates/cli-common": {
      "release-type": "rust",
      "component": "cli-common",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "package-name": "tftio-cli-common"
    },
    "crates/prompter": {
      "release-type": "rust",
      "component": "prompter",
      "changelog-path": "CHANGELOG.md",
      "package-name": "tftio-prompter"
    },
    "crates/unvenv": {
      "release-type": "rust",
      "component": "unvenv",
      "changelog-path": "CHANGELOG.md",
      "package-name": "tftio-unvenv"
    },
    "crates/asana-cli": {
      "release-type": "rust",
      "component": "asana-cli",
      "changelog-path": "CHANGELOG.md",
      "package-name": "tftio-asana-cli"
    },
    "crates/todoer": {
      "release-type": "rust",
      "component": "todoer",
      "changelog-path": "CHANGELOG.md",
      "package-name": "tftio-todoer"
    },
    "crates/silent-critic": {
      "release-type": "rust",
      "component": "silent-critic",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "package-name": "tftio-silent-critic"
    },
    "crates/gator": {
      "release-type": "rust",
      "component": "gator",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "package-name": "tftio-gator"
    },
    "crates/bsky-comment-extractor": {
      "release-type": "rust",
      "component": "bsky-comment-extractor",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "package-name": "tftio-bsky-comment-extractor"
    }
  },
  "plugins": [
    {
      "type": "cargo-workspace",
      "merge": true,
      "updateAllPackages": true
    },
    {
      "type": "linked-versions",
      "groupName": "workspace",
      "components": [
        "cli-common",
        "prompter",
        "unvenv",
        "asana-cli",
        "todoer",
        "silent-critic",
        "gator",
        "bsky-comment-extractor"
      ],
      "merge": true
    }
  ],
  "separate-pull-requests": false
}
